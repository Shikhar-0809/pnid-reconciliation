# LLM provider: gemini | groq | local
LLM_PROVIDER=gemini

# API keys (never commit real values)
GEMINI_API_KEY=your-gemini-api-key-here
GROQ_API_KEY=your-groq-api-key-here

# Local Ollama (when LLM_PROVIDER=local; requires Ollama running + model pulled)
OLLAMA_BASE_URL=http://localhost:11434

# Model names (Gemini defaults; for Groq use vision-capable VLM, e.g.):
# VLM_MODEL_NAME=meta-llama/llama-4-scout-17b-16e-instruct
# For local Ollama use a vision model, e.g.:
# LLM_PROVIDER=local
# VLM_MODEL_NAME=qwen2.5vl:7b
# TEXT_MODEL_NAME=qwen2.5vl:7b
VLM_MODEL_NAME=gemini-2.0-flash
TEXT_MODEL_NAME=gemini-2.0-flash

# Extraction confidence threshold (0.0–1.0)
CONFIDENCE_THRESHOLD=0.7

# Request timeouts (seconds)
VLM_TIMEOUT_SECONDS=120.0
TEXT_TIMEOUT_SECONDS=60.0

# Retry budget for rate-limited free tiers
MAX_RETRIES=3

# Paths
SCENARIOS_DIR=scenarios
EXTRACTION_CACHE_DIR=.cache/extraction
EXTRACTION_PROMPT_VERSION=1
DATABASE_PATH=pnid_recon.db
